# Honeypot API — Variables de entorno
#
# ⚠️  Railway: NO uses .env para producción.
# Las variables se configuran en Railway Dashboard:
#   - El plugin PostgreSQL inyecta automáticamente PGHOST, PGPORT, PGUSER, PGPASSWORD, PGDATABASE
#   - SPRING_PROFILES_ACTIVE=prod se define en docker-compose.yml
#
# Para desarrollo local con PostgreSQL:
# Copiar este archivo como .env y ajustar valores

POSTGRES_DB=honeypot
POSTGRES_USER=honeypot
POSTGRES_PASSWORD=changeme

SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/honeypot
SPRING_DATASOURCE_USERNAME=honeypot
SPRING_DATASOURCE_PASSWORD=changeme
