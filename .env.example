# Honeypot API — Variables de entorno
# Copiar este archivo como .env y ajustar los valores

# PostgreSQL
POSTGRES_DB=honeypot
POSTGRES_USER=honeypot
POSTGRES_PASSWORD=changeme

# Backend
SPRING_DATASOURCE_URL=jdbc:postgresql://db:5432/honeypot
SPRING_DATASOURCE_USERNAME=honeypot
SPRING_DATASOURCE_PASSWORD=changeme
